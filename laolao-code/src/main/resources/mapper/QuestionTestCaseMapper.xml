<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.laolao.mapper.QuestionTestCaseMapper">
    <insert id="insertBatch">
        INSERT INTO question_test_case (question_id, input, output)
        VALUES
        <foreach collection="testCases" item="item" separator=",">
            (#{item.questionId}, #{item.input}, #{item.output})
        </foreach>
    </insert>
    <select id="selectBatchByQuestionIds" resultType="com.laolao.pojo.entity.QuestionTestCase">
        select id, question_id, input, output
        from question_test_case
        where question_id in
        <foreach collection="questionIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>