<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.laolao.mapper.TeamMapper">
    <select id="selectAllTeam" resultType="com.laolao.pojo.vo.AdminTeamVO">
        select t.id,
               t.name,
               t.description,
               t.manager_id,
               u.username as managerUsername,
               u.name     as managerName,
               t.invite_code,
               t.status
        from team t
                 join user u on u.id = t.manager_id
        <where>
            <if test="content != null and content != ''">
                t.name like concat('%',#{content},'%')
            </if>
        </where>
    </select>
</mapper>