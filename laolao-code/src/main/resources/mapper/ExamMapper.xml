<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.laolao.mapper.ExamMapper">
    <select id="selectQuestionById" resultType="com.laolao.pojo.vo.ExamQuestionVO">
        select id, title, content, difficulty, template_code
        from question
        where id in
        <foreach collection="questionIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>